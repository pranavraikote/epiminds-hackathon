# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Redis (Memorystore internal IP, or localhost for dev)
REDIS_HOST=localhost
REDIS_PORT=6379

# Reddit API (optional — fallback activates if missing)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=swarm-agency/1.0

# Product Hunt API (optional — get token at producthunt.com/v2/oauth/applications)
PRODUCTHUNT_TOKEN=your-producthunt-token
